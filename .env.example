# --- Server ---
APP_ENV=development

# --- Database ---
# Default is local SQLite. For production use PostgreSQL, e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/farmeragent
DATABASE_URL=sqlite:///./farmeragent.db

# --- LINE Messaging API ---
# Leave empty for local development (webhook signature check + reply are skipped).
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- Embeddings ---
# hashing = offline deterministic embedder (no keys). openai = OpenAI-compatible API.
EMBEDDINGS_PROVIDER=hashing
EMBEDDINGS_DIM=256
EMBEDDINGS_MODEL=text-embedding-3-small

# --- LLM ---
# stub = offline extractive/grounded responder (no keys).
# anthropic = Claude (Messages API) | openai = OpenAI-compatible API.
LLM_PROVIDER=stub
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude. NOTE: needs an Anthropic API key (console.anthropic.com) with
# credits. A claude.ai Pro/Max subscription does NOT provide API access.
# To use Claude: set LLM_PROVIDER=anthropic and ANTHROPIC_API_KEY below.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# --- Retrieval / guardrails ---
RETRIEVAL_TOP_K=4
RETRIEVAL_MIN_SCORE=0.18

# --- Admin portal ---
ADMIN_TOKEN=change-me-admin-token
